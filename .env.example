# ─── Server ─────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── MCP Authentication ──────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MCP_API_KEY=your_strong_random_mcp_api_key_here_min_32_chars

# ─── Supabase (same project as main backend) ─────────────
SUPABASE_URL=https://your_project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# ─── CORS (who can call this MCP server) ─────────────────
# Comma-separated list of allowed origins (for browser-based MCP Inspector)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
